{
    "name": "Magic Mirror Companion Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "workspaceFolder": "/workspaces/BirthdayCalendar",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        }
    },
    "remoteUser": "vscode",
    "remoteEnv": {
        "CC": "clang",
        "CXX": "clang++"
    },
    "postCreateCommand": "cd frontend && npm install && cd ../backend && cmake -B build -S . -DCMAKE_BUILD_TYPE=Debug",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "svelte.svelte-vscode",
                "dbaeumer.vscode-eslint"
            ]
        }
    }
}